# Telegram bot for contact form notifications (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email notifications (SMTP) — все формы → support@elizon.ru
CONTACT_EMAIL=support@elizon.ru
