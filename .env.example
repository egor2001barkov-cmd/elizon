SMTP_USER=support@elizon.ru
SMTP_PASS=your_app_password_here
SMTP_FROM="ELIZON <support@elizon.ru>"

# Public site URL (for payment return links)
NEXT_PUBLIC_SITE_URL=https://elizon.ru